{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/activate-meta-theory-spine.mjs --package-root __REPO_ROOT__",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|MultiEdit|NotebookEdit|Agent|spawn_agent",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/enforce-agent-dispatch.mjs --runtime codex",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/graphify-context.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/post-format.mjs"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/post-typecheck.mjs"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/post-console-log-warn.mjs"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/subagent-context.mjs"
          }
        ]
      }
    ],
    "Skill": [
      {
        "matcher": "meta-theory",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/activate-meta-theory-spine.mjs --package-root __REPO_ROOT__",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/stop-compaction.mjs"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/stop-console-log-audit.mjs"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/stop-completion-guard.mjs"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/stop-spine-cleanup.mjs"
          }
        ]
      }
    ]
  }
}
