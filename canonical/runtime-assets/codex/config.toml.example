# Copy this file to ~/.codex/config.toml and replace REPLACE_WITH_REPO_ROOT
# with the absolute path to this repository.
#
# Project custom agents are auto-loaded from:
#   REPLACE_WITH_REPO_ROOT/.codex/agents/
# Project skills are auto-discovered from:
#   REPLACE_WITH_REPO_ROOT/.agents/skills/

# model and model_reasoning_effort are inherited from your Codex CLI configuration
approval_policy = "on-request"
sandbox_mode = "workspace-write"
suppress_unstable_features_warning = true

[features]
# Enables Codex's native request_user_input surface in Default mode.
# Actual rendering is owned by the active Codex host.
default_mode_request_user_input = true

[agents]
max_threads = 6
max_depth = 1

[mcp_servers.meta_kim_runtime]
command = "node"
args = ["REPLACE_WITH_REPO_ROOT/scripts/mcp/meta-runtime-server.mjs"]
