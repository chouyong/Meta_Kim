# ========== Dependencies ==========
node_modules/
npm-debug.log*
pnpm-lock.yaml
package-lock.json

# ========== Secrets (never commit; preventive — project has no .env yet) ==========
.env
.env.*
!.env.example

# ========== Local-only Claude skills (not synced via sync:runtimes; optional personal overlay) ==========
canonical/skills/commit-review/

# ========== Runtime Projections (Generated from canonical/) ==========
# These are DERIVED assets, NOT source. Edit canonical/ instead.
/.vscode/
/.claude/
/.mcp.json
/.codex/
/codex/
/.agents/
/openclaw/
/openclaw/workspaces/*/.openclaw/
/shared-skills/
/.cursor/

# ========== Local State (Never commit) ==========
.meta-kim/
.meta-kim/state/
.meta-kim/local.overrides.json
test-output/

# ========== Code Knowledge Graph (Generated by graphify) ==========
graphify-out/

# ========== Runtime Directories ==========
runtimes/

# ========== Auto-generated Records (Not source code) ==========
memory/
.reports/

# ========== Operational Snapshots (Local Only) ==========
# These change frequently and are project-internal, not user-facing.
todos.json
docs/todo-list.md
docs/agent-health-report.md
scripts/generate-todo-list.mjs

# ========== Release Artifacts (Embedded in gh release bodies, not tracked) ==========
# Release notes are published as gh release bodies; local drafts stay outside git.
.release-notes-v*.md
# Progress snapshots are historical, kept outside git.
progress-v*.md
# Versioned RFC drafts are internal-only, not public.
docs/v*-rfc-*.md

# ========== Test run output (generated; keep tests/*.test.mjs & fixtures tracked) ==========
tests/output/
tests/.cache/
tests/CC-e2e/

# ========== Planning & Progress (local scratch) ==========
task_plan.md
progress.md
findings.md

# ========== Backup / Temporary ==========
.backup/
tmp/

# ========== Terminal / Shell Cache Files ==========
*.omp.cache
pwsh.*.omp.cache
pip/


# ========== Root-level images ==========
/images/

# ========== Lib directories ==========
# (docs/lib/ may be created by some build tools)
lib/
*/lib/
*/node_modules/
# v2.2.0 exception: canonical abstraction modules live under shared/lib/ on purpose
!canonical/runtime-assets/shared/lib/
!canonical/runtime-assets/shared/lib/**

# ========== Docs Privacy Boundary ==========
# docs/ is local-private by default. Keep only README images public.
docs/**
!docs/
!docs/images/
!docs/images/**
!docs/runtime/
!docs/runtime/**

# ========== Generated reports ==========
docs/agent-design-quality-eval-report.zh-CN.md
docs/capability-gap-codex-real-test-report.zh-CN.md
docs/capability-gap-isolated-task-report.zh-CN.md
docs/governance-agent-benchmark-review.zh-CN.md
docs/governance-agent-process-mvp-report.zh-CN.md
