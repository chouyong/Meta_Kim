# Meta_Kim 环境变量示例
#
# 本项目的环境变量是「配置开关」和「路径定位」，不是用来存密码的。
# 大部分变量由 hook 自动注入，或从系统环境读取。
#
# 只有需要覆盖默认值时才复制此文件为 `.env`。
# `.env` 被 gitignore 忽略；本文件 `.env.example` 是文档，提交到 git。

## === 治理开关 ===
# 治理严格度：progressive（默认，先警告再拦）/ block（立即拦）/ warn（只警告）/ off（关）
# META_KIM_CAPABILITY_GATE=progressive

# 跳过治理 hook（仅紧急调试用，生产别开）
# META_KIM_HOOK_SKIP=

# 关闭 memory 服务自启动
# META_KIM_DISABLE_MEMORY_AUTOSTART=

# hook 运行时选择（同一 hook 投影到多 runtime 时）
# META_KIM_HOOK_RUNTIME=claude

## === 路径定位 ===
# Claude Code 配置目录（默认 ~/.claude）
# META_KIM_CLAUDE_HOME=

# Codex 配置目录（默认 ~/.codex）
# META_KIM_CODEX_HOME=

# Codex hooks.json 路径覆盖
# META_KIM_CODEX_HOOKS_JSON=

# Cursor 配置目录（默认 ~/.cursor）
# META_KIM_CURSOR_HOME=

# Cursor hooks.json 路径覆盖
# META_KIM_CURSOR_HOOKS_JSON=

## === MCP 记忆服务 ===
# memory 二进制路径（默认从 PATH 找）
# MCP_MEMORY_BIN=

# memory 服务 URL（默认 http://localhost:8000）
# MCP_MEMORY_URL=

# 允许 memory 服务连远程（默认只本地/内网，安全考虑）
# 设 false 强制要求认证；默认 true 兼容本地自启动
# META_KIM_ALLOW_REMOTE_MEMORY=

## === 依赖发现 ===
# 扫描兄弟决策协议候选的根目录（分号分隔）
# META_KIM_DEP_ROOTS=

## === 网络 / 平台 ===
# HTTP/HTTPS 代理（标准变量，npm 和 fetch 都认）
# HTTP_PROXY=
# HTTPS_PROXY=
