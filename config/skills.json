{
  "$schema": "./contracts/skills-manifest.schema.json",
  "schemaVersion": 1,
  "skillOwner": "KimYx0207",
  "skills": [
    {
      "id": "agent-teams-playbook",
      "repo": "${skillOwner}/agent-teams-playbook",
      "installMethod": "gitCloneInstallScript",
      "targets": [
        "claude",
        "codex",
        "openclaw",
        "cursor"
      ]
    },
    {
      "id": "findskill",
      "repo": "${skillOwner}/findskill",
      "installMethod": "subdirExtraction",
      "subdirTemplate": "{platform}",
      "subdirMapping": {
        "win32": "windows",
        "default": "original"
      },
      "legacyNames": ["find-skills"],
      "targets": [
        "claude",
        "codex",
        "openclaw",
        "cursor"
      ]
    },
    {
      "id": "hookprompt",
      "repo": "${skillOwner}/HookPrompt",
      "installMethod": "manual",
      "capabilities": [
        "prompt-submission-optimization"
      ],
      "platformSupport": {
        "claude": {
          "status": "native",
          "events": ["UserPromptSubmit"],
          "adapter": "claude-settings-hook"
        },
        "codex": {
          "status": "adapter-required",
          "events": ["UserPromptSubmit"],
          "adapter": "codex-hookprompt-adapter"
        },
        "openclaw": {
          "status": "degraded",
          "events": ["command:new"],
          "adapter": "openclaw-workspace-instruction"
        },
        "cursor": {
          "status": "adapter-required",
          "events": ["beforeSubmitPrompt"],
          "adapter": "cursor-hookprompt-adapter"
        }
      },
      "fallback": {
        "openclaw": "Use workspace boot and agent instructions; no direct Claude hook execution.",
        "cursor": "Use Cursor beforeSubmitPrompt through the Meta_Kim adapter; do not reuse Claude hook output directly."
      },
      "globalHookSubdirs": {
        "claude": ["~/.claude/hooks/meta-kim"]
      },
      "hookExtraFiles": {
        "claude": [
          { "src": ".claude/prompt-optimizer-meta.md", "dest": "prompt-optimizer-meta.md" }
        ]
      },
      "hookSettingsMerge": {
        "claude": {
          "event": "UserPromptSubmit",
          "hookFile": "user-prompt-submit.js",
          "timeout": 10000
        }
      },
      "targets": [
        "claude",
        "codex",
        "cursor"
      ]
    },
    {
      "id": "superpowers",
      "repo": "obra/superpowers",
      "claudePlugin": "superpowers@superpowers-marketplace",
      "codexPlugin": "superpowers",
      "cursorPlugin": "superpowers",
      "installMethod": "pluginMarketplace",
      "fallbackContentDir": "skills",
      "targets": [
        "claude",
        "codex",
        "openclaw",
        "cursor",
        "opencode"
      ]
    },
    {
      "id": "ecc",
      "repo": "affaan-m/ECC",
      "claudePlugin": "ecc@ecc",
      "installMethod": "upstreamCli",
      "upstreamPackage": "ecc-universal@latest",
      "upstreamProfile": "core",
      "legacyNames": ["everything-claude-code"],
      "platformSupport": {
        "claude": { "status": "native", "adapter": "claude-plugin" },
        "codex": { "status": "native", "adapter": "ecc-home-installer" },
        "cursor": { "status": "native", "adapter": "ecc-project-installer" },
        "opencode": { "status": "native", "adapter": "ecc-home-installer" },
        "qwen": { "status": "native", "adapter": "ecc-home-installer" },
        "zed": { "status": "native", "adapter": "ecc-project-installer" },
        "gemini": { "status": "native", "adapter": "ecc-project-installer" },
        "codebuddy": { "status": "native", "adapter": "ecc-project-installer" },
        "antigravity": { "status": "native", "adapter": "ecc-project-installer" },
        "joycode": { "status": "native", "adapter": "ecc-project-installer" }
      },
      "targets": [
        "claude",
        "codex",
        "cursor",
        "opencode",
        "qwen",
        "zed",
        "gemini",
        "codebuddy",
        "antigravity",
        "joycode"
      ]
    },
    {
      "id": "planning-with-files",
      "repo": "OthmanAdi/planning-with-files",
      "installMethod": "subdirExtraction",
      "subdir": "skills/planning-with-files",
      "pluginHookCompat": true,
      "globalHookSubdirs": {
        "codex": ["~/.codex/hooks/meta-kim"],
        "cursor": ["~/.cursor/hooks/meta-kim"]
      },
      "globalHookConfigFiles": {
        "codex": "~/.codex/hooks.json",
        "cursor": "~/.cursor/hooks.json"
      },
      "targets": [
        "claude",
        "codex",
        "openclaw",
        "cursor"
      ]
    },
    {
      "id": "cli-anything",
      "repo": "HKUDS/CLI-Anything",
      "installMethod": "pluginMarketplace",
      "defaultSelected": false,
      "targets": [
        "claude",
        "codex",
        "openclaw",
        "cursor"
      ]
    },
    {
      "id": "gstack",
      "repo": "garrytan/gstack",
      "installMethod": "gitCloneInstallScript",
      "targets": [
        "claude",
        "codex",
        "openclaw",
        "cursor"
      ]
    },
    {
      "id": "skill-creator",
      "repo": "anthropics/skills",
      "installMethod": "subdirExtraction",
      "subdir": "skills/skill-creator",
      "targets": [
        "claude",
        "codex",
        "openclaw",
        "cursor"
      ]
    }
  ],
  "externalUrls": {
    "claudeCodeDocs": "https://docs.anthropic.com/en/docs/claude-code",
    "author": {
      "website": "https://www.aiking.dev/",
      "github": "https://github.com/KimYx0207",
      "feishu": "https://my.feishu.cn/wiki/OhQ8wqntFihcI1kWVDlcNdpznFf",
      "x": "https://x.com/KimYx0207"
    }
  }
}
