{
  "schemaVersion": 1,
  "availableTargets": [
    "claude",
    "codex",
    "openclaw",
    "cursor"
  ],
  "supportedTargets": [
    "claude",
    "codex",
    "openclaw",
    "cursor"
  ],
  "defaultTargets": [
    "claude",
    "codex"
  ],
  "canonicalRoots": {
    "agents": "canonical/agents",
    "skills": "canonical/skills",
    "runtimeAssets": "canonical/runtime-assets",
    "contracts": "config/contracts",
    "capabilityIndex": "config/capability-index"
  },
  "projectMaterializationPolicy": {
    "defaultAssetMode": "global_reusable_by_default",
    "globalByDefault": [
      "agents",
      "commands",
      "mcp",
      "skills"
    ],
    "projectMaterializationTrigger": "project_specific_customization_or_iteration_innovation",
    "projectRuntimeAssetCopyPolicy": "copy_to_project_when_explicit_project_update_or_project_dedicated_extension",
    "projectAllowedBase": [
      "runtime_entry_context",
      "merged_project_config",
      "project_cache_state",
      "project_evolution_records",
      "project_specific_capability_overrides"
    ],
    "projectStatePaths": [
      ".meta-kim/state",
      ".meta-kim/cache",
      ".meta-kim/backups",
      ".meta-kim/local.overrides.json"
    ]
  },
  "generatedTargets": {
    "claude": [
      ".claude/agents",
      ".claude/skills",
      ".claude/settings.json",
      ".mcp.json",
      ".claude/capability-index"
    ],
    "codex": [
      ".codex/agents",
      ".agents/skills",
      ".codex/capability-index",
      ".codex/hooks.json",
      ".codex/commands",
      ".codex/config.toml",
      "codex/config.toml.example"
    ],
    "openclaw": [
      "openclaw/workspaces",
      "openclaw/skills",
      "openclaw/capability-index",
      "openclaw/openclaw.template.json"
    ],
    "cursor": [
      ".cursor/agents",
      ".cursor/skills",
      ".cursor/hooks.json",
      ".cursor/capability-index",
      ".cursor/mcp.json",
      ".cursor/rules"
    ]
  }
