    {
      "id": "meta-kim-decision-patterns",
      "type": "file_set",
      "name": "Meta_Kim Decision Patterns",
      "description": "Internal stage-bound decision patterns for intent lock, evidence labeling, path mapping, risk-to-skill binding, minimum test, pass/kill review, and adversarial cross-validation.",
      "triggerConditions": [
        "fuzzy strategy",
        "product monetization",
        "minimum test",
        "pass/kill gate",
        "intent analysis",
        "PR or issue triage",
        "skill prioritization",
        "public-ready decision"
      ],
      "taskShapes": [
        "fuzzy_strategy_task",
        "product_monetization_task"
      ],
      "inputContract": {
        "requires": [
          "surface decision",
          "constraints"
        ],
        "optional": [
          "evidence",
          "audience"
        ]
      },
      "outputContract": {
        "produces": [
          "intent frame",
          "evidence labels",
          "path candidates",
          "minimum test",
          "pass signal",
          "kill signal"
        ]
      },
      "ownerCandidates": [
        "meta-warden",
        "meta-conductor",
        "meta-artisan",
        "meta-prism"
      ],
      "dependencyProjects": [],
      "runtimeSupport": {
        "claude_code": "native",
        "codex": "native",
        "openclaw": "native",
        "cursor": "native"
      },
      "osSupport": {
        "macos": "supported",
        "windows": "supported",
        "wsl2": "supported",
        "linux": "supported"
      },
      "howToTrigger": {
        "explicit": "Read config/governance/decision-pattern-catalog.json",
        "implicit": "Critical/Fetch/Thinking/Review for fuzzy or decision-heavy tasks",
        "config": "config/governance/decision-pattern-catalog.json",
        "hook": null
      },
      "risk": {
        "canMutateFiles": false,
        "canExecuteShell": false,
        "canUseNetwork": false,
        "canReadSecrets": false,
        "requiresApproval": false,
        "requiresTrustReview": false
      },
      "verification": {
        "command": "npm run meta:route:validate",
        "artifact": "route output",
        "passCondition": "Recalled for fuzzy strategy/product tasks as internal Meta_Kim data, never as external dependency or implementation owner."
      }
    },
    {
      "id": "select-execution-route",
