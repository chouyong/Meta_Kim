{
  "schemaVersion": 1,
  "weapons": [
    {
      "id": "runtime-capability-matrix",
      "type": "file_set",
      "name": "Runtime Capability Matrix",
      "description": "Runtime support, trigger, evidence, and OS compatibility registry.",
      "triggerConditions": [
        "platform capability needed",
        "hooks/skills/MCP/subagents/sandbox/approval involved"
      ],
      "taskShapes": [
        "platform_governance",
        "platform_hook_install"
      ],
      "inputContract": {
        "requires": [
          "runtime or capability question"
        ]
      },
      "outputContract": {
        "produces": [
          "platformCapabilityPacket",
          "runtimeSupportGapReport"
        ]
      },
      "ownerCandidates": [
        "meta-scout",
        "meta-sentinel",
        "meta-artisan"
      ],
      "dependencyProjects": [],
      "runtimeSupport": {
        "claude_code": "native",
        "codex": "native",
        "openclaw": "partial",
        "cursor": "partial"
      },
      "osSupport": {
        "macos": "supported",
        "windows": "supported",
        "wsl2": "supported",
        "linux": "supported"
      },
      "howToTrigger": {
        "explicit": "Read config/runtime-capability-matrix.json",
        "implicit": "Fetch when platform claims affect route",
        "config": "config/runtime-capability-matrix.json",
        "hook": null
      },
      "risk": {
        "canMutateFiles": false,
        "canExecuteShell": false,
        "canUseNetwork": false,
        "canReadSecrets": false,
        "requiresApproval": false,
        "requiresTrustReview": false
      },
      "verification": {
        "command": "npm run meta:runtime:validate",
        "artifact": "config/runtime-capability-matrix.json",
        "passCondition": "All platforms and critical capabilities have support/confidence/trigger/evidence."
      }
    },
