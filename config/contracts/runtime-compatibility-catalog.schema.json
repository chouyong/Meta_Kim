{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-kim.dev/contracts/runtime-compatibility-catalog.schema.json",
  "title": "Meta_Kim Runtime Compatibility Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "lastReviewedAt",
    "decisionBoundary",
    "tierDefinitions",
    "surfaceTaxonomy",
    "promotionRules",
    "products"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "lastReviewedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "decisionBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "noAutoPromotionFromDependencyInstall",
        "noAutoPromotionFromGenericSkillPath",
        "noFormalClaimFromSurfaceMatch",
        "formalRuntimeSource"
      ],
      "properties": {
        "noAutoPromotionFromDependencyInstall": { "type": "boolean" },
        "noAutoPromotionFromGenericSkillPath": { "type": "boolean" },
        "noFormalClaimFromSurfaceMatch": { "type": "boolean" },
        "formalRuntimeSource": { "type": "string" }
      }
    },
    "tierDefinitions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_projection",
        "dependency_install_target",
        "candidate_probe"
      ],
      "properties": {
        "runtime_projection": { "type": "string" },
        "dependency_install_target": { "type": "string" },
        "candidate_probe": { "type": "string" }
      }
    },
    "surfaceTaxonomy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instruction_context",
        "skill_workflow",
        "agent_mode",
        "hook_automation",
        "mcp_tooling",
        "command_cli",
        "memory_context",
        "permission_safety"
      ],
      "properties": {
        "instruction_context": { "type": "string" },
        "skill_workflow": { "type": "string" },
        "agent_mode": { "type": "string" },
        "hook_automation": { "type": "string" },
        "mcp_tooling": { "type": "string" },
        "command_cli": { "type": "string" },
        "memory_context": { "type": "string" },
        "permission_safety": { "type": "string" }
      }
    },
    "promotionRules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredForRuntimeProjection"
      ],
      "properties": {
        "requiredForRuntimeProjection": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "minItems": 1
        }
      }
    },
    "products": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "tier",
          "formalProjection",
          "genericCompatibility",
          "dependencyInstall",
          "evidence",
          "decision",
          "nextAction"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "label": { "type": "string" },
          "tier": {
            "type": "string",
            "enum": [
              "runtime_projection",
              "dependency_install_target",
              "candidate_probe"
            ]
          },
          "formalProjection": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "inSyncManifest",
              "hasRuntimeProfile",
              "hasProjectionLayout",
              "isDefaultTarget"
            ],
            "properties": {
              "inSyncManifest": { "type": "boolean" },
              "hasRuntimeProfile": { "type": "boolean" },
              "hasProjectionLayout": { "type": "boolean" },
              "isDefaultTarget": { "type": "boolean" }
            }
          },
          "genericCompatibility": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "skillPath",
              "agentPath",
              "hookConfig",
              "mcpConfig",
              "status"
            ],
            "properties": {
              "skillPath": { "type": ["string", "null"] },
              "agentPath": { "type": ["string", "null"] },
              "hookConfig": { "type": ["string", "null"] },
              "mcpConfig": { "type": ["string", "null"] },
              "status": {
                "type": "string",
                "enum": [
                  "verified_current",
                  "partial",
                  "not_applicable",
                  "needs_probe"
                ]
              }
            }
          },
          "compatibilitySurfaces": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "instruction_context",
                "skill_workflow",
                "agent_mode",
                "hook_automation",
                "mcp_tooling",
                "command_cli",
                "memory_context",
                "permission_safety"
              ]
            },
            "uniqueItems": true,
            "minItems": 1
          },
          "dependencyInstall": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "ecc"
            ],
            "properties": {
              "ecc": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "support",
                  "mode",
                  "evidenceRef"
                ],
                "properties": {
                  "support": {
                    "type": "string",
                    "enum": [
                      "native",
                      "not_supported",
                      "not_applicable"
                    ]
                  },
                  "mode": {
                    "type": "string",
                    "enum": [
                      "home_installer",
                      "project_installer",
                      "claude_plugin",
                      "not_applicable"
                    ]
                  },
                  "evidenceRef": { "type": ["string", "null"] }
                }
              }
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "type",
                "ref",
                "claim"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "local_file",
                    "command_output",
                    "github_issue",
                    "official_docs"
                  ]
                },
                "ref": { "type": "string" },
                "claim": { "type": "string" }
              }
            }
          },
          "decision": { "type": "string" },
          "nextAction": { "type": "string" }
        }
      }
    }
  }
}
