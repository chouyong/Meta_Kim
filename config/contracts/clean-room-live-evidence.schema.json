{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-kim.local/contracts/clean-room-live-evidence.schema.json",
  "title": "Meta_Kim clean-room live evidence",
  "type": "object",
  "required": ["schemaVersion", "runId", "status", "isolation"],
  "properties": {
    "schemaVersion": { "const": "clean-room-live-acceptance-v0.1" },
    "runId": { "type": "string", "minLength": 16 },
    "target": { "enum": ["codex_cli", "codex_desktop", "claude_code"] },
    "scenario": { "enum": ["governed_execution", "fast_path_control"] },
    "status": { "enum": ["preflight_pass", "install_pass", "orchestration_observed", "release_attested", "blocked"] },
    "promotionEligible": { "type": "boolean" },
    "exactBindingCoverage": { "type": "boolean" },
    "attestation": {
      "type": "object",
      "required": ["algorithm", "keyId", "signatureBase64", "signedPayloadSha256"],
      "properties": {
        "algorithm": { "const": "Ed25519" },
        "keyId": { "const": "meta-kim-release-observer-ed25519-2b0848f46fe6c6d72" },
        "signatureBase64": { "type": "string", "minLength": 64 },
        "signedPayloadSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "requiredBindings": { "type": "array", "minItems": 1 },
    "observedBindings": { "type": "array", "minItems": 1 },
    "isolation": {
      "type": "object",
      "required": [
        "home",
        "runtimeHome",
        "packageWorkspace",
        "packageSha256",
        "siblingAgentTeamsPlaybookAbsent",
        "globalInventoryInjectionConfigured",
        "promptSha256",
        "promptLint"
      ],
      "properties": {
        "siblingAgentTeamsPlaybookAbsent": { "const": true },
        "globalInventoryInjectionConfigured": { "const": false },
        "promptLint": {
          "type": "object",
          "required": ["pass", "hits"],
          "properties": {
            "pass": { "const": true },
            "hits": { "type": "array", "maxItems": 0 }
          }
        }
      }
    },
    "observation": {
      "type": "object",
      "required": ["rawArtifact", "rawSha256", "eventCount", "events", "boundary"],
      "properties": {
        "eventCount": { "type": "integer", "minimum": 0 },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "observerFormat",
              "family",
              "eventId",
              "hostSurface",
              "providerId",
              "resultStatus",
              "inputDigest",
              "outputDigest"
            ],
            "properties": {
              "observerFormat": {
                "enum": [
                  "codex_host_jsonl_v1",
                  "claude_stream_json_v1",
                  "claude_hook_event_v1",
                  "mcp_stdio_client_v1"
                ]
              },
              "family": {
                "enum": ["agent_subagent", "skill", "mcp", "hook", "command_script", "runtime_tool"]
              },
              "resultStatus": { "const": "completed" }
              ,"batchId": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "orchestration_observed" }
        }
      },
      "then": {
        "required": ["target", "promotionEligible", "exactBindingCoverage", "observation"]
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "release_attested" }
        }
      },
      "then": {
        "required": [
          "target",
          "promotionEligible",
          "exactBindingCoverage",
          "attestation",
          "requiredBindings",
          "observedBindings"
        ],
        "properties": {
          "promotionEligible": { "const": true },
          "exactBindingCoverage": { "const": true }
        }
      }
    }
  ]
}
