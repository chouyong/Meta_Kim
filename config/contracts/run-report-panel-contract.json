{
  "schemaVersion": "run-report-panel-contract-v0.1",
  "owner": "meta-warden",
  "producer": "scripts/run-meta-theory-governed-execution.mjs",
  "purpose": "Stable reader-facing data contract for a runId product panel. The UI reads this contract instead of parsing internal protocol packets directly.",
  "requiredSections": [
    "decisionSummary",
    "ownerHandoff",
    "blockedReasons",
    "runtimeEvidence",
    "productExperience",
    "visibleMetaTheorySurface",
    "capabilityInvocationTruth",
    "approvalRequest",
    "aiReadableRubric",
    "deliverables"
  ],
  "sectionRules": {
    "decisionSummary": {
      "requiredFields": [
        "runId",
        "status",
        "task",
        "gapCount",
        "workerTaskCount",
        "plainLanguageSummary"
      ]
    },
    "ownerHandoff": {
      "requiredFields": [
        "taskPacketId",
        "roleDisplayName",
        "owner",
        "parallelGroup",
        "mergeOwner",
        "verificationOwner"
      ]
    },
    "blockedReasons": {
      "requiredFields": [
        "gapId",
        "reason",
        "returnToStage",
        "remainingAction"
      ]
    },
    "runtimeEvidence": {
      "requiredFields": [
        "runtime",
        "status",
        "evidenceKind",
        "failureClass",
        "remainingAction",
        "strictReleasePass"
      ],
      "blockedOrUnsupportedIsNotPass": true
    },
    "productExperience": {
      "requiredFields": [
        "status",
        "evidenceTier",
        "nativeRuntimeBoundary",
        "goals",
        "supportGates",
        "nativeChoiceSurfaceGate",
        "repeatFailureDesignGate",
        "generalizationGate",
        "capabilityInvocationTruthGate",
        "agentTeamsPlaybookGate",
        "noOverclaimGate"
      ],
      "allowedStatuses": ["product_experience_pass", "partial"],
      "fullPassRequiredBy": "npm run meta:prd:product-experience:validate",
      "requiredGoalIds": ["P-102", "P-103", "P-104"],
      "supportGateIds": ["P-105", "P-106", "P-107", "P-108", "P-109", "P-110"]
    },
    "visibleMetaTheorySurface": {
      "requiredFields": [
        "status",
        "requiredVisibleTopics",
        "orchestration",
        "dynamicWorkflow",
        "capabilityInventory",
        "capabilityInvocationTruth",
        "agentTeamsPlaybook",
        "peerAgentMesh",
        "langGraph"
      ],
      "requiredTopics": [
        "orchestration",
        "dynamic_workflow",
        "capability_inventory_not_skill_only",
        "capability_invocation_truth",
        "agent_teams_playbook",
        "peer_agent_mesh",
        "langgraph_style_control_graph"
      ],
      "allowedStatuses": ["pass", "partial"],
      "fullPassRequiredBy": "npm run meta:prd:product-experience:validate"
    },
    "capabilityInvocationTruth": {
      "requiredFields": [
        "status",
        "stateTaxonomy",
        "stateCounts",
        "requiredFamilies",
        "truthAssertions",
        "callableInvocationCoverage",
        "realInvocationCoverage",
        "rows"
      ],
      "requiredFamilies": [
        "agent_subagent",
        "app_visible_subagent",
        "worker_task",
        "skill",
        "mcp",
        "hook",
        "prompt_rule",
        "command_script",
        "runtime_tool",
        "agent_teams_playbook"
      ],
      "allowedStates": [
        "invoked",
        "applied",
        "host_visible_observed",
        "selected_not_invoked",
        "discovered_not_selected",
        "unavailable",
        "not_authorized",
        "blocked",
        "not_required"
      ],
      "allowedStatuses": ["pass", "partial"],
      "fullPassRequiredBy": "npm run meta:prd:product-experience:validate"
    },
    "approvalRequest": {
      "requiredFields": [
        "approvalRequired",
        "approvalValidation",
        "dryRunCanonicalWrites",
        "candidateCount",
        "nextAction"
      ],
      "canonicalWritesBeforeApproval": 0
    },
    "aiReadableRubric": {
      "requiredFields": [
        "id",
        "label",
        "plainLanguageQuestion",
        "passStandard",
        "failStandard",
        "requiredEvidence",
        "status"
      ],
      "requiredStandardCount": 5
    },
    "deliverables": {
      "requiredFields": [
        "json",
        "markdown",
        "sqlite",
        "panelContract"
      ],
      "forbidAbsoluteLocalPaths": true
    }
  },
  "forbidden": [
    "raw absolute local paths in user-facing values",
    "credentials or secret values",
    "runtime nicknames as primary owner names",
    "claiming release-grade completion when runtime evidence is projection-only, unsupported, or blocked",
    "writing canonical without Warden approval"
  ],
  "acceptance": {
    "allRequiredSectionsPresent": true,
    "aiReadableRubricStatusPass": true,
    "blockedRuntimeRemainsVisible": true,
    "approvalBoundaryVisible": true,
    "panelReadsSingleContract": true
  }
}
