{
  "contractId": "stage-runtime-control-contract",
  "version": "1.0.0",
  "prdTaskId": "P-115",
  "status": "ready",
  "purpose": "Keep the eight-stage spine mechanically executable by separating stage action policy, stage commit requirements, and side-effect authorization.",
  "sourceOfTruth": {
    "human": "docs/ai-native-capability-gap-mvp-prd.zh-CN.md",
    "machine": [
      "canonical/runtime-assets/shared/hooks/spine-state.mjs",
      "canonical/runtime-assets/claude/hooks/enforce-agent-dispatch.mjs"
    ]
  },
  "controlPlaneRules": {
    "stageDriver": "runner_or_stage_runtime_only",
    "hookRole": "last_resort_fuse",
    "hookMustNotAdvanceStage": true,
    "businessWorkflowMayBlockTools": false,
    "sideEffectsRequireExecutionStage": true
  },
  "stageChecks": {
    "actionPolicy": {
      "description": "Checks whether the current tool action is allowed while a stage is in progress.",
      "mustNotRequireCommitPackets": true,
      "designStagesMayProceedWithoutAgentDispatch": true
    },
    "commitRequirements": {
      "description": "Checks whether a stage can be marked completed and the next stage entered.",
      "requiresExplicitTransitionIntent": true
    },
    "executionLease": {
      "description": "Checks whether a business mutation side effect is allowed after Thinking has committed owner, loadout, evidence, memory strategy, and review standard.",
      "requiredForBusinessMutation": true
    }
  },
  "activationPolicy": {
    "autoPromptActivation": {
      "creates": "hook_observed",
      "driverMode": "hook_observed",
      "hookGateMode": "advisory",
      "hardGateAllowedBeforeManagedDriver": false,
      "purpose": "Natural-language triggers create user-visible continuity state only. They must not impersonate a stage driver or force packet archaeology before ordinary local execution."
    },
    "managedDriverActivation": {
      "creates": "managed_stage_runtime",
      "driverMode": "managed",
      "hookGateMode": "block",
      "hardGateAllowedBeforeMutation": true,
      "purpose": "Only a runner or trusted stage runtime that can write Critical/Fetch/Thinking packets may enable strict pre-execution blocking."
    },
    "staleStateRotation": {
      "legacyStateWithoutControlMayRotate": true,
      "observedPromptChangeMayRotate": true,
      "managedStateMustNotRotateAutomatically": true
    }
  },
  "factGatePolicy": {
    "singleExecutionLease": true,
    "observedMode": "advisory_not_blocking",
    "observedExplicitPublishIntent": "allows_narrow_git_push_and_github_release_only",
    "managedMode": "required_before_mutation",
    "mustNotBecomeIndependentHookLoop": true,
    "fileChangeFactCardBelongsTo": "Fetch/Thinking execution lease"
  },
  "routeSelectionPolicy": {
    "typeFirstRouteRef": "scripts/select-execution-route.mjs#typeFirstRoutePolicy",
    "kind": "route_selection_invariant",
    "mustNotBecomeNewGate": true,
    "unclearTypeDisposition": "degrade_or_block_not_guess",
    "purpose": "Make the best route default by classifying object, evidence, and ownership types during Fetch/Thinking instead of adding validator or hook rescue loops."
  },
  "fetchPolicy": {
    "inProgressMustAllow": [
      "read_file",
      "repo_search",
      "git_status",
      "config_scan",
      "capability_scan",
      "dependency_discovery",
      "validator_dry_run",
      "spine_state_write",
      "planning_file_update",
      "visible_status_notice"
    ],
    "inProgressMustDelay": [
      "task_bookkeeping_control_plane_until_fetch_evidence"
    ],
    "inProgressMustNotRequire": [
      "fetchRecord",
      "businessFlowBlueprintPacket",
      "workerTaskPackets",
      "agentDispatch"
    ],
    "commitRequires": [
      "fetchRecord",
      "capabilitySearchPerformed"
    ]
  },
  "thinkingPolicy": {
    "inProgressMustNotRequire": [
      "agentDispatch"
    ],
    "commitRequires": [
      "owner",
      "ownerLoadout",
      "memoryStrategy",
      "reviewStandard",
      "workerTaskPacketsOrNoBranchingChoice"
    ]
  },
  "regressionRequirements": [
    "fetch_in_progress_does_not_require_fetchRecord_until_commit",
    "fetch_and_thinking_in_progress_do_not_require_agent_dispatch",
    "read_only_hook_allowance_does_not_auto_advance_stage",
    "fetch_stage_allows_spine_state_write_before_fetchRecord",
    "fetch_stage_allows_planning_files_before_fetchRecord",
    "fetch_stage_delays_task_bookkeeping_before_fetch_evidence",
    "fetch_business_mutation_denial_does_not_instruct_agent_dispatch",
    "fetch_self_lock_allows_repair_only_fetchRecord_write",
    "business_mutation_still_denied_without_execution_readiness",
    "auto_prompt_activation_creates_hook_observed_advisory_state",
    "observed_state_allows_ordinary_local_mutation",
    "observed_state_allows_local_git_stage_commit",
    "observed_state_denies_high_risk_external_side_effects",
    "observed_state_ignores_high_risk_words_inside_quoted_readonly_search_text",
    "observed_state_allows_explicit_user_authorized_git_release_commands_only",
    "stale_legacy_active_state_rotates_on_new_prompt"
  ],
  "verificationCommand": "npm run meta:prd:stage-runtime-control:validate"
}
