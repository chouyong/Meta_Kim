{
  "schemaVersion": 1,
  "choiceRequiredWhen": [
    "choice changes scope",
    "choice changes risk or cost",
    "choice changes owner or verification owner",
    "choice changes runtime or OS",
    "choice changes dependency adoption",
    "choice changes public-ready acceptance",
    "read-only work still has branch-changing options"
  ],
  "choiceForbiddenWhen": [
    "AI can inspect the answer locally",
    "question is filler",
    "approval overlay would be used for product choice",
    "choice does not alter route/scope/risk/acceptance/owner/permission/non-goal"
  ],
  "readOnlyPolicy": "Read-only/queryBypass is a safety and path-classification boundary, not a choice-surface skip reason by itself. Ask when branch-changing options exist; skip only when no user answer would change the route, scope, risk, owner, permission, non-goal, or acceptance.",
  "triggerProofPolicy": {
    "nativeSurfaceAvailableMeansCallIt": true,
    "primaryRuntimesNoDowngrade": ["codex", "claude_code"],
    "primaryRuntimeUnavailableAction": "block_before_execution",
    "artifactOnlyIsNotTriggered": true,
    "completionEvidence": [
      "native_tool_answer",
      "deferred_native_tool_call",
      "valid_choice_gate_skip"
    ],
    "compatibilityOnlyEvidence": ["conversation_fallback_reason"],
    "artifactOnlySignals": [
      "cardPlanPacket",
      "conversationNotice",
      "markdown_report",
      "hook_warning",
      "generated_run_artifact"
    ],
    "description": "When Codex or Claude Code needs a branch-changing choice, the runtime assistant must actually call or defer the native tool. Generated packets and notices only prove that a choice is needed; they do not prove the user saw a popup. If the primary native surface is unavailable, block before Execution instead of accepting a chat-card fallback. Conversation fallback is compatibility-only for non-primary runtimes."
  },
  "falseNativeChoiceClaimPolicy": {
    "enabled": true,
    "failureClass": "false_native_choice_claim",
    "claimDefinition": "Assistant text states or implies that a runtime choice surface was shown, sent, used, returned empty, timed out, completed, or selected.",
    "appliesTo": [
      "assistant_chat_text",
      "run_report",
      "conversation_notice",
      "artifact_summary"
    ],
    "claimPhrases": [
      "I used the choice panel",
      "choice panel did not return",
      "popup did not return",
      "native choice was shown",
      "我用 Codex 的选择面板",
      "选择面板没有返回",
      "弹框没有返回",
      "已弹出选择"
    ],
    "evidenceByRuntime": {
      "codex": {
        "acceptedEvidence": [
          "request_user_input_answer",
          "nativeChoiceSurfaceBlocked"
        ],
        "forbiddenSubstitutes": [
          "chat_text",
          "markdown_card",
          "conversationNotice",
          "cardPlanPacket",
          "run_report"
        ],
        "fallbackAllowed": false
      },
      "claude_code": {
        "acceptedEvidence": [
          "AskUserQuestion_answer",
          "deferred_AskUserQuestion_tool_call",
          "nativeChoiceSurfaceBlocked"
        ],
        "forbiddenSubstitutes": [
          "chat_text",
          "markdown_card",
          "conversationNotice",
          "cardPlanPacket",
          "run_report"
        ],
        "fallbackAllowed": false
      },
      "cursor": {
        "acceptedEvidence": [
          "verified_native_choice_answer",
          "conversation_fallback_user_reply"
        ],
        "mustLabelFallback": true,
        "forbiddenClaim": "native_popup"
      },
      "openclaw": {
        "acceptedEvidence": [
          "verified_native_choice_answer",
          "conversation_fallback_user_reply",
          "channel_user_reply"
        ],
        "mustLabelFallback": true,
        "forbiddenClaim": "native_popup"
      },
      "structural_runner": {
        "acceptedEvidence": [
          "hostInvocationRequestPacket",
          "host_handoff_pending"
        ],
        "mustLabelPending": true,
        "forbiddenClaim": "choice_completed"
      }
    },
    "rule": "A choice-surface claim is valid only when the current runtime adapter attaches matching evidence. If evidence is missing, report the exact pending or blocked state instead of narrating a result."
  },
  "platformChoiceSurfaces": {
    "claude_code": [
      {
        "surface": "AskUserQuestion",
        "support": "native",
        "notes": "Primary runtime surface. Required branch-changing decisions must use AskUserQuestion or deferred AskUserQuestion; no chat-card downgrade is accepted."
      }
    ],
    "codex": [
      {
        "surface": "request_user_input",
        "support": "native",
        "notes": "Primary runtime surface. Required branch-changing decisions must use request_user_input; no chat-card downgrade is accepted."
      }
    ],
    "openclaw": [
      {
        "surface": "channel_message_or_gateway_ui",
        "support": "partial",
        "notes": "Remote channel input is untrusted; high-risk skills require pairing, allowlist, or sandbox."
      },
      {
        "surface": "chat_decision_card",
        "support": "native",
        "notes": "Portable fallback."
      }
    ],
    "cursor": [
      {
        "surface": "native_choice",
        "support": "unknown",
        "notes": "Only upgrade after verified docs or local proof."
      },
      {
        "surface": "chat_decision_card",
        "support": "native",
        "notes": "Rules, MCP, and Agent context are not native choice popups."
      }
    ]
  },
  "fallback": "chat_decision_card",
  "cardContract": {
    "optionsMin": 2,
    "maximumOptionsPolicy": "use_active_runtime_native_schema_maximum_meaningful_options_without_meta_kim_lower_cap",
    "requiresRecommendedDefault": true,
    "eachOptionMustHave": [
      "bestFor",
      "benefit",
      "cost",
      "risk",
      "expectedResult",
      "verification"
    ]
  },
  "nativeStructuredPanelContract": {
    "requiredForPrimaryRuntimes": ["codex", "claude_code"],
    "hostOwnsVisualSkin": true,
    "metaKimOwnsPayloadStructure": true,
    "requiredPanelSections": [
      "AI understanding",
      "AI additions",
      "Capability route",
      "Candidate paths"
    ],
    "requiredOptionSemantics": [
      "recommended default",
      "expected result",
      "advantages",
      "disadvantages or risk",
      "verification impact"
    ],
    "runtimeNativeOptionPolicy": {
      "optionsMin": 2,
      "strategy": "use_active_host_schema_maximum_meaningful_options",
      "noMetaKimLowerCap": true,
      "overActiveHostMaximumBehavior": "show_host_maximum_best_options_and_record_omitted_alternatives",
      "currentObservedHostMaximums": {
        "codex": {
          "source": "active request_user_input tool schema",
          "questionsMax": 3,
          "optionsMax": 3,
          "notProductCap": true
        },
        "claude_code": {
          "source": "active AskUserQuestion host schema",
          "optionsMax": 4,
          "notProductCap": true
        }
      }
    },
    "forbidden": [
      "plain_yes_no_prompt_for_branching_decision",
      "meta_kim_lower_option_cap",
      "fixed_codex_option_cap",
      "oversized_native_payload_retry_unchanged",
      "unstyled_question_without_tradeoffs",
      "chat_card_as_primary_runtime_completion"
    ]
  },
  "intentConfirmationCard": {
    "cardType": "intent_confirmation",
    "requiredFields": [
      "surfaceRequest",
      "understoodIntent",
      "confirmedDimensions",
      "uncertainDimensions"
    ],
    "confirmationStates": ["pending", "confirmed", "corrected", "skipped"],
    "allowedSkipReasons": ["trivial", "explicit_auto_proceed"],
    "renderHint": "Show confirmed items as checkmarks, uncertain items as numbered questions. Prompt: reply 'yes' to confirm, or correct specific items.",
    "surfacePreference": "For Codex and Claude Code, use the primary native choice surface and block if it cannot run. For compatibility runtimes only, fall back to chat card via the standard fallback chain."
  },
  "choiceSurfaceAdapterContract": {
    "purpose": "Separate the canonical decision card from runtime-specific renderer schemas.",
    "canonicalCardTypes": ["intent_confirmation", "pre_execution_decision"],
    "adapterMayCompressForRenderer": true,
    "adapterMustPreserve": [
      "decision purpose",
      "route-changing dimension",
      "recommended default",
      "runtime-native maximum option policy",
      "option trade-offs",
      "structured panel sections",
      "runtime payload limits and host maximums",
      "selection result",
      "blocking reason or compatibility fallback reason",
      "native trigger proof or artifact-only boundary",
      "writeback target"
    ],
    "canonicalMustNotContain": [
      "renderer-specific payload schema",
      "host-only option decoration",
      "tool-specific field mapping",
      "one-runtime-only labels"
    ],
    "runtimeSpecificMappingsLiveIn": [
      "canonical/skills/meta-theory/references/runtime-claude.md",
      "canonical/skills/meta-theory/references/runtime-codex.md",
      "config/runtime-capability-matrix.json"
    ]
  },
  "codexUxRisks": [
    "request_user_input may be unavailable outside Plan mode or specific host surfaces",
    "inactive subagent approval can surface unexpectedly",
    "non-interactive mode cannot satisfy fresh approval UI"
  ]
}
